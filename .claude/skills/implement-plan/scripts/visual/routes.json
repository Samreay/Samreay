{
  "$schema": "Per-route visual diff config. `phase` gates when the route enters the corpus.",
  "routes": [
    {
      "path": "/",
      "phase": 7,
      "name": "home",
      "mask": [".newsletter-form", "footer"]
    },
    {
      "path": "/kitchensink/",
      "phase": 3,
      "name": "kitchensink",
      "mask": [],
      "astro_only": true
    },
    {
      "path": "/reviews/bobiverse/",
      "phase": 5,
      "name": "review-bobiverse",
      "mask": [".newsletter-form"]
    },
    {
      "path": "/reviews/100th_run/",
      "phase": 5,
      "name": "review-100th-run",
      "mask": [".newsletter-form"]
    },
    {
      "path": "/blogs/2023_07_writing_update/",
      "phase": 5,
      "name": "blog-2023-07",
      "mask": [".newsletter-form"]
    },
    {
      "path": "/tutorials/bayesianlinearregression/",
      "phase": 5,
      "name": "tutorial-bayesian",
      "mask": []
    },
    {
      "path": "/reviews/",
      "phase": 8,
      "name": "reviews-explorer",
      "mask": [".newsletter-form", "[data-review-card]"],
      "astro_only": true
    },
    {
      "path": "/artists/",
      "phase": 9,
      "name": "artists",
      "mask": ["[data-artist-cover]"],
      "astro_only": true,
      "skip_visual": true
    },
    {
      "path": "/blogs/",
      "phase": 9,
      "name": "blogs-index",
      "mask": ["[data-tagged-card]"],
      "astro_only": true
    },
    {
      "path": "/tutorials/",
      "phase": 9,
      "name": "tutorials-index",
      "mask": ["[data-tagged-card]"],
      "astro_only": true
    }
  ]
}
