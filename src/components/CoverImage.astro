---
/**
 * CoverImage — single source of cover-image truth across the site.
 *
 * Resolution order:
 *   1. Explicit `src` prop (already an `ImageMetadata`, e.g. an imported file).
 *   2. `entry.data.images[0]` if the entry's frontmatter set it (rare).
 *   3. A co-located `cover.{jpg,jpeg,png,webp,gif}` inside the entry bundle.
 *   4. A bundled cover keyed by `entry.id` under
 *      `src/assets/img/covers/<id>.{jpg,png,webp}` — used by reviews where
 *      the cover lives with the artist asset bundle, not the review entry.
 *      (Pre-cutover this directory was `themes/sams-theme/assets/img/covers/`;
 *      Phase 14 moved it into `src/assets/`.)
 *   5. A deterministic placeholder rotation based on entry.date.getMonth().
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  entry?: {
    id: string;
    collection?: string;
    data: {
      images?: string[];
      short_title?: string;
      name?: string;
      title?: string;
      date?: Date;
    };
  };
  src?: ImageMetadata;
  width: number;
  height: number;
  class?: string;
  alt?: string;
  loading?: 'lazy' | 'eager';
}

const {
  entry,
  src: explicitSrc,
  width,
  height,
  class: className = '',
  alt: altProp,
  loading = 'lazy',
} = Astro.props;

const colocatedCovers = import.meta.glob<{ default: ImageMetadata }>(
  '/content/**/{cover,thumbnail}.{jpg,jpeg,png,webp,gif}',
  { eager: true }
);
const themeCovers = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/img/covers/*.{jpg,jpeg,png,webp}',
  { eager: true }
);
const placeholders = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/img/jeff/placeholder_*.{jpg,jpeg,png,webp}',
  { eager: true }
);

function findCover(): ImageMetadata | undefined {
  if (!entry) return undefined;
  if (entry.data.images?.[0]) {
    const wanted = entry.data.images[0].toLowerCase();
    const match = Object.entries(colocatedCovers).find(
      ([path]) => path.includes(`/${entry.id}/`) && path.toLowerCase().endsWith(wanted)
    );
    if (match) return match[1].default;
  }
  const colocated = Object.entries(colocatedCovers).find(([path]) =>
    path.includes(`/${entry.id}/`)
  );
  if (colocated) return colocated[1].default;
  const theme = Object.entries(themeCovers).find(([path]) => {
    const stem = path.split('/').pop()!.split('.')[0];
    return stem === entry.id;
  });
  if (theme) return theme[1].default;
  return undefined;
}

function pickPlaceholder(): ImageMetadata {
  // Sort by the numeric suffix in `placeholder_<n>.<ext>` so we don't get the
  // lexicographic ordering (1, 10, 11, …, 19, 2, 20, …) that `import.meta.glob`
  // returns by default.
  const sorted = Object.entries(placeholders)
    .map(([path, mod]) => {
      const m = path.match(/placeholder_(\d+)\./);
      return { n: m ? parseInt(m[1], 10) : 0, img: mod.default };
    })
    .sort((a, b) => a.n - b.n)
    .map((x) => x.img);
  if (sorted.length === 0) {
    throw new Error('CoverImage: no placeholder images found');
  }
  // 31 placeholders, one per day-of-month — pick by `getDate()` so each
  // post deterministically ties to the same image.
  const day = entry?.data.date?.getDate() ?? 1;
  return sorted[(day - 1) % sorted.length];
}

const src: ImageMetadata = explicitSrc ?? findCover() ?? pickPlaceholder();
const alt = altProp ?? entry?.data.short_title ?? entry?.data.name ?? entry?.data.title ?? '';
---
<picture>
  <Image
    src={src}
    width={width}
    height={height}
    quality={70}
    format="webp"
    loading={loading}
    decoding="async"
    class={className}
    alt={alt}
  />
</picture>
