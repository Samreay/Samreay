---
/**
 * Newsletter signup CTA, backed by Mailerlite (form 176526142171252164,
 * account 2036924).
 *
 * Two visual variants:
 *
 *   - `default` — full-width card centred on the page; used by review and
 *     blog detail pages where the form is its own block in the article
 *     flow.
 *   - `compact` — fits inside a sibling grid cell; used by the home-page
 *     `<Books />` section so the CTA sits in the third column next to two
 *     book covers.
 *
 * Mailerlite needs both their `webforms.min.js` loader and a per-form
 * "takel" tracking pixel; the success callback is keyed on the form id
 * (the `ml_webform_success_35716688` global). We render those once per
 * page — if the form happens to appear twice (currently no page does
 * this), Mailerlite tolerates the duplicate script tag.
 */
interface Props {
  variant?: 'default' | 'compact';
  /**
   * Extra classes appended to the outer `.fancy_card` wrapper. Useful for
   * grid-positioning (e.g. `md:col-start-2` on the home page Books section)
   * without introducing an extra wrapper div that would shift the visual
   * baseline.
   */
  class?: string;
}
const { variant = 'default', class: extraClass = '' } = Astro.props;

const DISCORD_URL = 'https://discord.gg/tfn4HVEaDz';

// Outer wrappers diverge between variants; everything inside
// `.newsletter-inner` is identical.
const outerClassBase =
  variant === 'compact'
    ? 'fancy_card flex flex-col h-full'
    : 'relative max-w-xl mx-auto my-20 fancy_card horizontal';
const outerClass = extraClass ? `${extraClass} ${outerClassBase}` : outerClassBase;
const translatorClass = variant === 'compact' ? 'card_translator h-full' : 'card_translator';
const rotatorClass =
  variant === 'compact'
    ? 'card_rotator tiny_rot h-full card_layer block'
    : 'card_rotator tiny_rot card_layer';
const newsletterClass =
  variant === 'compact'
    ? 'newsletter card_layer h-full'
    : 'card_layer newsletter p-1';
const newsletterInnerClass = 'newsletter-inner h-full';
const newsletterPadStyle = variant === 'compact' ? 'padding: 0.2rem;' : '';
const headerWrapperClass =
  variant === 'compact' ? 'mb-6 text-center' : 'mb-6 lg:mb-12 text-center';
const headlineClass =
  variant === 'compact' ? 'text-main-50 mb-2 lg:mb-8' : 'text-main-200 mb-2 lg:mb-8';
const headlineText = variant === 'compact' ? 'Updates!' : 'Stay in the loop!';
const subClass =
  variant === 'compact'
    ? 'text-main-50 text-lg text-opacity-70 mb-2'
    : 'text-main-100 text-lg text-opacity-70 mb-2';
---
<div class={outerClass}>
  <div class={translatorClass}>
    <div class={rotatorClass}>
      <div class={newsletterClass} style={newsletterPadStyle}>
        <div class={newsletterInnerClass}>
          <div class="relative h-full sib-form-container">
            <div class={headerWrapperClass}>
              {variant === 'compact' ? (
                <h3 class={headlineClass}>{headlineText}</h3>
              ) : (
                <h3 class={headlineClass} style="padding-top: 0;">{headlineText}</h3>
              )}
              {variant === 'compact' ? (
                <p class={subClass}>
                  Join
                  {' '}
                  <a href={DISCORD_URL} class="font-bold" style="color: #7289da;">discord</a>
                  {' '}
                  to chat, or the email list!
                </p>
              ) : (
                <p class={subClass}>
                  For new books, giveaways, reviews, and chatting, join my
                  {' '}
                  <a href={DISCORD_URL} class="no-under font-bold" style="color: #7289da;">discord</a>.
                  For new releases and giveaways without socialising, join the newletter!
                </p>
              )}
            </div>
            <form
              action="https://assets.mailerlite.com/jsonp/2036924/forms/176526142171252164/subscribe"
              method="post"
              target="_blank"
              data-code=""
              class="validate w-full ml-block-form"
              novalidate
            >
              <div class="ml-form-formContent">
                <input
                  type="email"
                  name="fields[email]"
                  required
                  data-required="true"
                  aria-required="true"
                  placeholder="Your best email…"
                  aria-label="Your best email…"
                  class="w-full appearance-none bg-main-600 mb-4 border border-main-600 bg-opacity-5 focus:border-main-300 rounded-sm px-4 py-3 text-main-100 placeholder-main-100 required"
                />
                <div style="position: absolute; left: -5000px;" aria-hidden="true">
                  <input type="hidden" name="ml-submit" tabindex="-1" value="1" />
                </div>
                <input
                  type="submit"
                  value="Subscribe"
                  class="button btn bg-main-600 hover:bg-main-400 shadow w-full"
                />
                <input type="hidden" name="anticsrf" value="true" />
              </div>
              <p
                style="display: none"
                class="text-center mt-2 opacity-50 text-main-200"
                data-status="error"
              >
                There was a problem, please try again.
              </p>
              <p
                style="display: none"
                class="text-center mt-2 opacity-50 text-main-200"
                data-status="success"
              >
                Thanks mate, won't let ya down.
              </p>
            </form>
          </div>
        </div>
      </div>
      {variant === 'compact' ? null : (
        <div class="card_layer card_effect card_soft_glare" style="pointer-events: none;"></div>
      )}
    </div>
  </div>
</div>

<script is:inline async src="https://groot.mailerlite.com/js/w/webforms.min.js?v176e10baa5e7ed80d35ae235be3d5024"></script>
<script is:inline>
  fetch("https://assets.mailerlite.com/jsonp/2036924/forms/176526142171252164/takel");
  function ml_webform_success_35716688() {
    document.querySelectorAll('[data-status="success"]').forEach((el) => {
      el.style.display = 'block';
    });
    document.querySelectorAll('.ml-form-formContent').forEach((el) => {
      el.style.display = 'none';
    });
  }
</script>
