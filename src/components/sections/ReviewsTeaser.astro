---
import { getCollection } from 'astro:content';
import ReviewCoverCard from '../ReviewCoverCard.astro';

const reviews = (await getCollection('reviews'))
  .sort((a, b) => +b.data.date - +a.data.date)
  .slice(0, 5);
---
<div class="content content-wide">
  <div class="section-header">
    <h1>Book Reviews</h1>
    <p>
      For those loving progression fantasy and LitRPG, here are my latest reviews.
      <a class="under" href="/reviews">More available here, of course!</a>
      And if you want an fun flowchart or tier list, that's available too!
    </p>
  </div>
  <div class="max-w-sm mx-auto md:max-w-none">
    <div class="grid gap-12 md:grid-cols-3 lg:grid-cols-4 lg:grid-cols-5 md:gap-x-6 md:gap-y-8 items-start">
      {reviews.map((entry) => <ReviewCoverCard entry={entry} />)}
    </div>
  </div>
</div>
