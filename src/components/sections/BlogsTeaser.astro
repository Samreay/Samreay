---
import { getCollection } from 'astro:content';
import PostCard from '../PostCard.astro';

const blogs = (await getCollection('blogs'))
  .sort((a, b) => +b.data.date - +a.data.date)
  .slice(0, 6);
---
<div class="content content-wide">
  <div class="section-header">
    <h1>Latest Blog Posts</h1>
    <p>
      Writing updates, extra content, travel, and outreach. Its a catch all of my life, basically.
      <a class="under" href="/tutorials">Perhaps too many more here.</a>
    </p>
  </div>
  <div class="max-w-sm mx-auto md:max-w-none mt-8">
    <div class="grid gap-12 grid-cols-vertical-cards items-start">
      {blogs.map((entry) => <PostCard entry={entry} />)}
    </div>
  </div>
</div>
