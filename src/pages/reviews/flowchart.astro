---
/**
 * /reviews/flowchart/ — Phase 16 validation slice.
 *
 * Three nodes (one decision, two book recommendations) laid out by dagre at
 * build time, rendered by `@xyflow/svelte` inside a `client:only` Svelte
 * island. The same data feeds an always-rendered `<details>` fallback so
 * the page has crawlable text content and screen readers have a working
 * non-canvas reading path even though the canvas itself is JS-only.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Flowchart from '../../components/islands/Flowchart.svelte';
import { flowchart } from '../../data/flowchart';
import { getLayoutedElements } from '../../lib/flowchart-layout';
import '../../styles/flowchart.css';

// NOTE: the design doc asked for `?refine=1` to be read here and passed
// to `getLayoutedElements`. That path does not work in Astro's
// `output: 'static'` mode: prerendered routes (which this page is, since
// it must ship in `dist/`) have their query string stripped from both
// `Astro.url` and `Astro.request.url` — the route key is the pathname,
// nothing more. Making this page `prerender = false` would let the
// query through in dev but drop the page from the production build,
// which is unacceptable.
//
// Instead the dev-only "Save & Refine" toolbar button POSTs to the
// `/api/flowchart-positions.json` endpoint with `{ refine: true }` and
// the endpoint runs the relax pass server-side before returning.
// That keeps refining as a dev-only behaviour (the endpoint 403s in
// production), keeps this page purely declarative, and avoids any
// URL-string round-trip.
const { nodes, edges } = await getLayoutedElements(flowchart);

// Build a flat list of every "from this decision, see X or Y" pair so we
// can render an `sr-only` fallback for crawlers, screen readers, and
// JS-disabled users. With `client:only` the canvas itself contributes
// zero text content to the static HTML; this hidden block is the page's
// only indexable body. Visually it's removed from the page so the canvas
// owns the full viewport — the trade-off is intentional.
const bookNodesById = new Map(
  nodes.flatMap((n) => (n.type === 'book' ? [[n.id, n] as const] : [])),
);
const fallback = flowchart.decisions.map((d) => {
  const branches = flowchart.edges
    .filter((e) => e.source === d.id)
    .flatMap((e) => {
      const node = bookNodesById.get(e.target);
      return node
        ? [{ label: e.label ?? '', title: node.data.title, href: node.data.link }]
        : [];
    });
  return { prompt: d.prompt, branches };
});
---
<BaseLayout
  title="Flowchart"
  description="Pick your next progression-fantasy / LitRPG read by branching question."
>
  <div class="flowchart-page">
    <div class="flowchart-page__header">
      <h1>Recommendation Flowchart</h1>
    </div>

    {/*
      The island self-detects dev via `import.meta.env.DEV` rather than
      receiving a `dev` prop from here. Both signals would be the same
      compile-time constant, and Vite tree-shakes the island's dev
      branch on its own — passing the prop would just duplicate the
      truth. If the page itself ever needs to conditionally render
      something dev-only (a banner, debug link), do `import.meta.env.DEV`
      directly here.
    */}
    <Flowchart client:only="svelte" {nodes} {edges} />

    <div class="sr-only" aria-label="Flowchart as a list">
      {fallback.map((d) => (
        <section>
          <h2>{d.prompt}</h2>
          <ul>
            {d.branches.map((b) => (
              <li>
                <strong>{b.label}:</strong>{' '}
                <a href={b.href}>{b.title}</a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
